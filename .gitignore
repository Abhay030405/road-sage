# =============================================================================
# RoadSage — root .gitignore
# Stack: Python 3.10 · FastAPI · OpenCV · PyTorch/ONNX · Vite/React dashboard
# =============================================================================

# -----------------------------------------------------------------------------
# Python bytecode & import cache
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/
node_modules/

# -----------------------------------------------------------------------------
# Frontend / JS build artifacts
# -----------------------------------------------------------------------------
.vite/
dist-ssr/
coverage/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Python packaging & build artifacts
# -----------------------------------------------------------------------------
*.egg
*.egg-info/
*.whl
dist/
build/
PYTHONPATH
site/

# -----------------------------------------------------------------------------
# Environment & secrets  (keep .env.example as a template)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Jupyter notebooks — checkpoint directories only, keep .ipynb files
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# ML model weights & binaries  (download via models/download_models.sh)
# -----------------------------------------------------------------------------
*.pt
*.pth
*.onnx
*.pkl
*.h5
*.hdf5
*.tflite
*.bin
*.ckpt
*.safetensors
models/*.pt
models/*.pth
models/*.onnx

# -----------------------------------------------------------------------------
# ML experiment tracking & training outputs
# -----------------------------------------------------------------------------
wandb/
mlruns/
mlartifacts/
lightning_logs/
runs/
checkpoints/
training/runs/
training/outputs/
outputs/

# -----------------------------------------------------------------------------
# Dataset directories  (raw captures, pipeline outputs, external benchmarks)
# Large image collections live in cloud storage / DVC, not in git.
#
# NOTE: data/mnnit/verified/ and rgb/ were accidentally committed.
# To untrack them without deleting the files:
#   git rm -r --cached data/mnnit/verified/ rgb/
#   git commit -m "chore: untrack dataset images from git history"
# -----------------------------------------------------------------------------
rgb/
data/mnnit/raw/
data/mnnit/verified/
data/mnnit/pseudo_labels/
data/external/culane/
data/external/tusimple/
*.csv
*.parquet

# -----------------------------------------------------------------------------
# Logs & monitoring
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Docker local state
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/

# -----------------------------------------------------------------------------
# Type checking & linting caches
# -----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pytype/

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE & editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*~

# -----------------------------------------------------------------------------
# Misc temporary files
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.orig
*.local
