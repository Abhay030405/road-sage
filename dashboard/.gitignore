# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE & editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
