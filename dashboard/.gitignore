.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
.eslintcache
.cache/
*.tsbuildinfo

# -----------------------------------------------------------------------------
