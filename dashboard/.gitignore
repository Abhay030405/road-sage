# =============================================================================
# RoadSage dashboard — .gitignore
# Stack: Vite 5 · React 18 · ESLint · recharts · lucide-react
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build output  (generated by `vite build` / `vite preview`)
#
# NOTE: dist/ was committed accidentally. To untrack it:
#   git rm -r --cached dashboard/dist/
#   git commit -m "chore: untrack dashboard build output from git"
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/

# -----------------------------------------------------------------------------
# Vite & Rollup cache
# -----------------------------------------------------------------------------
.vite/
.cache/
*.local

# -----------------------------------------------------------------------------
# TypeScript build info  (emitted by tsc / vite dts plugin)
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment & secrets  (keep .env.example as a template)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# ESLint cache
# -----------------------------------------------------------------------------
.eslintcache

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE & editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
